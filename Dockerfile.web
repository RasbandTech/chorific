FROM node:20-bookworm-slim AS builder

RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml tsconfig.base.json ./

# Copy packages the frontend depends on
COPY lib/api-client-react/    lib/api-client-react/
COPY lib/api-zod/             lib/api-zod/
COPY lib/api-spec/            lib/api-spec/
COPY artifacts/chorific/      artifacts/chorific/

RUN pnpm install --no-frozen-lockfile

# Build the React app
# BASE_PATH=/ so the app is served from the root
# PORT is required by vite.config.ts but unused during build
ENV BASE_PATH=/
ENV PORT=3000
ENV NODE_ENV=production

RUN pnpm --filter @workspace/chorific run build

# ---- Serve with nginx ----
FROM nginx:1.27

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/artifacts/chorific/dist/public /usr/share/nginx/html

EXPOSE 80
